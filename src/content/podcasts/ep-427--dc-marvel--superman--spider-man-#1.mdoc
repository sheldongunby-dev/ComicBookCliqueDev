title: "Ep 427: DC/Marvel: Superman/ Spider-Man #1"
publishDate: "2026-04-02"
category: "major-issues"
episodeNumber: 428
spotifyUrl: "https://comicbookclique.podbean.com/e/ep-427-dcmarvel-superman-spider-man-1/"
